type LessonBook {
    id: ID!
    bookTitle: String!
    difficulty: String!
    language: String!
    chapters: [Chapter]!
}

input LessonBookRequestInput {
    language: String!
    difficulty: String!
}

extend type Query {
    getLessonBooks: [LessonBook!]!
    getLessonBook(request: LessonBookRequestInput!): LessonBook
}
