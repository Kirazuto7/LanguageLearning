scalar JSON

union WordDetails = GenericWordDetails | JapaneseWordDetails

type GenericWordDetails {
    nativeWord: String!
    phoneticSpelling: String!
}

type JapaneseWordDetails {
    kanji: String
    hiragana: String!
    katakana: String
    romaji: String
}

type Word {
    id: ID!
    englishTranslation: String!
    language: String!
    details: WordDetails!
}