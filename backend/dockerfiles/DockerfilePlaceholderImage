# Use an official lightweight Python image
FROM python:3.9-slim

# Set the working directory in the container
WORKDIR /app

# Copy the requirements file from the scripts subdirectory
COPY scripts/requirements.txt .

# Install the Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy the placeholder API script from the scripts subdirectory
COPY scripts/placeholder-image-api.py .

EXPOSE 7860

CMD ["python", "./placeholder-image-api.py"]
